# EcoTrade Environment Variables
GEMINI_API_KEY=
APP_URL=
PORT=3000

# Firebase Configuration (Overriding firebase-applet-config.json)
VITE_FIREBASE_PROJECT_ID=gen-lang-client-0307452548
VITE_FIREBASE_DATABASE_ID=(default)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Firebase Admin (Required for backend auth verification)
# Option 1: Path to service account key file
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json
# Option 2: Individual credentials (recommended for production)
FIREBASE_PROJECT_ID=gen-lang-client-0307452548
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@gen-lang-client-0307452548.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nABC123...\n-----END PRIVATE KEY-----\n"
FIREBASE_DATABASE_ID=(default)

# Flutterwave Payment Keys (Get these from https://dashboard.flutterwave.com)
FLW_SECRET_KEY=FLWSECK_TEST-MOCK-KEY
FLW_PUBLIC_KEY=FLWPUBK_TEST-MOCK-KEY
FLW_SECRET_HASH=your_webhook_secret_hash

# reCAPTCHA Keys
RECAPTCHA_SECRET=your_recaptcha_secret_here
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here

# Email Configuration (Gmail)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
