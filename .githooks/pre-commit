#!/bin/bash
# Pre-commit hook to prevent committing secrets
# Place in: .git/hooks/pre-commit

# List of secret patterns to check for
PATTERNS=(
  '\.env\.local'
  '\.env\.production'
  '*-firebase-adminsdk-.*\.json'
  'credentials\.json'
  'secrets\.json'
  'apiKey'
  'private_key'
  'auth_token'
  'password'
)

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

echo "Running pre-commit security check..."

# Check staged files
STAGED_FILES=$(git diff --cached --name-only)

for pattern in "${PATTERNS[@]}"; do
  if echo "$STAGED_FILES" | grep -qi "$pattern"; then
    echo -e "${RED}❌ ERROR: Potentially dangerous file detected: $pattern${NC}"
    echo "This file should NOT be committed (contains secrets/credentials)"
    echo "Add it to .gitignore instead"
    exit 1
  fi
done

# Check for secret patterns in code
if git diff --cached -U0 | grep -qi 'apiKey\|private_key\|AWS_SECRET\|FIREBASE_KEY'; then
  echo -e "${RED}❌ ERROR: Potential secret detected in code${NC}"
  echo "Review your changes before committing"
  exit 1
fi

echo -e "${GREEN}✅ Pre-commit check passed${NC}"
exit 0
