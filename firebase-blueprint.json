{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "name": { "type": "string" },
        "dob": { "type": "string", "description": "Date of Birth (DD/MM/YYYY)" },
        "phone": { "type": "string" },
        "whatsapp": { "type": "string" },
        "addresses": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "isDefault": { "type": "boolean" },
              "county": { "type": "string" },
              "subcounty": { "type": "string" },
              "ward": { "type": "string" },
              "street": { "type": "string" }
            }
          }
        },
        "avatar_url": { "type": "string" },
        "cover_url": { "type": "string" },
        "role": { "type": "string", "enum": ["buyer", "seller", "admin"] },
        "wallet_balance": { "type": "number" },
        "rating": { "type": "number" },
        "is_verified": { "type": "boolean" },
        "is_seller_verified": { "type": "boolean" },
        "national_id_encrypted": { "type": "string" },
        "deleted_at": { "type": "string", "format": "date-time" },
        "delete_token": { "type": "string" },
        "delete_expires": { "type": "string", "format": "date-time" },
        "email_change_token": { "type": "string" },
        "new_email": { "type": "string", "format": "email" },
        "failed_attempts": { "type": "integer" },
        "lock_until": { "type": "string", "format": "date-time" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "firstName", "lastName"]
    },
    "Listing": {
      "title": "Listing",
      "description": "Product listing for sale",
      "type": "object",
      "properties": {
        "seller_id": { "type": "string", "description": "UID of the seller" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "condition": { "type": "string" },
        "price": { "type": "number" },
        "is_negotiable": { "type": "boolean" },
        "location": { "type": "string" },
        "status": { "type": "string", "enum": ["available", "reserved", "sold"] },
        "images": { "type": "array", "items": { "type": "string" } },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["seller_id", "title", "price", "category"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Record of a purchase",
      "type": "object",
      "properties": {
        "listing_id": { "type": "string" },
        "buyer_id": { "type": "string" },
        "seller_id": { "type": "string" },
        "amount": { "type": "number" },
        "shipping_fee": { "type": "number" },
        "total_amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending_payment", "paid", "shipped", "delivered", "completed", "cancelled"] },
        "escrow_status": { "type": "string", "enum": ["pending", "held", "released", "refunded"] },
        "shipping_address": { "type": "object" },
        "payment_reference": { "type": "string" },
        "gateway_response": { "type": "object" },
        "tracking_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["listing_id", "buyer_id", "seller_id", "amount"]
    },
    "Offer": {
      "title": "Offer",
      "description": "Negotiation offer for a listing",
      "type": "object",
      "properties": {
        "listing_id": { "type": "string" },
        "buyer_id": { "type": "string" },
        "seller_id": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string" },
        "expires_at": { "type": "string", "format": "date-time" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["listing_id", "buyer_id", "seller_id", "amount"]
    },
    "Message": {
      "title": "Message",
      "description": "Chat message between users",
      "type": "object",
      "properties": {
        "sender_id": { "type": "string" },
        "receiver_id": { "type": "string" },
        "listing_id": { "type": "string" },
        "content": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["sender_id", "receiver_id", "content"]
    },
    "Review": {
      "title": "Review",
      "description": "User review after a transaction",
      "type": "object",
      "properties": {
        "transaction_id": { "type": "string" },
        "buyer_id": { "type": "string" },
        "seller_id": { "type": "string" },
        "rating": { "type": "integer" },
        "review_text": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["transaction_id", "buyer_id", "seller_id", "rating"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/listings/{listingId}": {
      "schema": "Listing",
      "description": "Marketplace listings"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Purchase records"
    },
    "/offers/{offerId}": {
      "schema": "Offer",
      "description": "Price negotiations"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Direct messages"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Transaction reviews"
    }
  }
}
